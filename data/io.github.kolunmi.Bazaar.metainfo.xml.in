<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.lucidos.Store</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Lucid Store</name>
  <summary>Discover and install applications</summary>
  <description>
    <p>
      Lucid Store is an application for discovering and installing Flatpak software,
      with a focus on simplicity, usability, and the LucidOS ecosystem.
    </p>
  </description>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <developer id="io.lucidos">
    <name>LucidOS Project</name>
  </developer>

  <!-- Only include URLs that exist or are placeholders -->
  <url type="homepage">https://lucidos.org/</url>
  <url type="vcs-browser">https://github.com/LucidOS-Project/lucid-store</url>
  <url type="bugtracker">https://github.com/LucidOS-Project/lucid-store/issues</url>
  
  <translation type="gettext">lucid-store</translation>
  <launchable type="desktop-id">io.lucidos.Store.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#ffbe6f</color>
    <color type="primary" scheme_preference="dark">#c11c2b</color>
  </branding>
</component>
